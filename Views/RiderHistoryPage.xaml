<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Shutool.ViewModels"
             xmlns:models="clr-namespace:Shutool.Models"
             x:Class="Shutool.Views.RiderHistoryPage"
             x:DataType="viewmodels:RiderHistoryViewModel"
             BackgroundImageSource="pixel_street_bg.png"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto, Auto, *" Padding="20, 40, 20, 20">

        <Grid Grid.Row="0" ColumnDefinitions="*, *" Margin="0,0,0,20">
            <Image Source="gear_icon.png" HorizontalOptions="Start" HeightRequest="30">
                <Image.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToProfileCommand}" />
                </Image.GestureRecognizers>
            </Image>

            <Image Source="lightning_icon.png" Grid.Column="1" HorizontalOptions="End" HeightRequest="30"/>
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="*, *" ColumnSpacing="10" Margin="0,0,0,20">
            <Button Text="Priority Request" 
                    Command="{Binding GoBackToPriorityCommand}"
                    BackgroundColor="#F5C518" 
                    TextColor="#1E3B20" 
                    FontAttributes="Bold"
                    CornerRadius="20"
                    HeightRequest="40"/>

            <Button Grid.Column="1"
                    Text="Request History" 
                    BackgroundColor="#73D073" 
                    TextColor="White" 
                    FontAttributes="Bold"
                    CornerRadius="20"
                    HeightRequest="40"/>
        </Grid>

        <Border Grid.Row="2" BackgroundColor="#F5EFE1" StrokeShape="RoundRectangle 30" StrokeThickness="0" Padding="20" VerticalOptions="FillAndExpand">
            <Grid RowDefinitions="Auto, Auto, *, Auto">

                <Image Grid.Row="0" Source="bus_pixel.png" HeightRequest="60" HorizontalOptions="Center" Margin="0,0,0,10"/>
                <Label Grid.Row="1" Text="Request History" TextColor="#1E3B20" FontAttributes="Bold" FontSize="18" HorizontalOptions="Center" Margin="0,0,0,15"/>

                <Border Grid.Row="2" BackgroundColor="White" StrokeShape="RoundRectangle 10" StrokeThickness="0" Padding="15">
                    <Grid RowDefinitions="Auto, *">

                        <Grid Grid.Row="0" ColumnDefinitions="2*, 2*, 2*, 1*" Margin="0,0,0,10">
                            <Label Text="Date" TextColor="Black" FontAttributes="Bold" FontSize="12"/>
                            <Label Grid.Column="1" Text="Time" TextColor="Black" FontAttributes="Bold" FontSize="12"/>
                            <Label Grid.Column="2" Text="Status" TextColor="Black" FontAttributes="Bold" FontSize="12"/>
                        </Grid>

                        <CollectionView Grid.Row="1" ItemsSource="{Binding RequestHistory}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:RequestModel">
                                    <SwipeView>
                                        <SwipeView.RightItems>
                                            <SwipeItems>
                                                <SwipeItem Text="Delete" BackgroundColor="#FF6B6B" 
                                                           Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:RiderHistoryViewModel}}, Path=DeleteRequestCommand}" 
                                                           CommandParameter="{Binding .}"/>
                                            </SwipeItems>
                                        </SwipeView.RightItems>

                                        <Grid ColumnDefinitions="2*, 2*, 2*, 1*" Padding="0,15">
                                            <Label Text="{Binding CreatedAt, StringFormat='{0:MMM dd}'}" TextColor="Black" FontSize="12" VerticalOptions="Center"/>
                                            <Label Grid.Column="1" Text="{Binding CreatedAt, StringFormat='{0:hh:mm tt}'}" TextColor="Black" FontSize="12" VerticalOptions="Center"/>
                                            <Label Grid.Column="2" Text="{Binding Status}" TextColor="#73D073" FontAttributes="Bold" FontSize="12" VerticalOptions="Center"/>
                                            <BoxView Grid.ColumnSpan="4" HeightRequest="1" Color="#E0D8C8" VerticalOptions="End"/>
                                        </Grid>
                                    </SwipeView>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Grid>
                </Border>

                <Button Grid.Row="3" Text="Refresh" Command="{Binding LoadHistoryCommand}" BackgroundColor="#5299D3" TextColor="White" FontAttributes="Bold" CornerRadius="20" WidthRequest="120" HorizontalOptions="Center" Margin="0,20,0,0"/>
            </Grid>
        </Border>
    </Grid>
</ContentPage>