<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Shutool.ViewModels"
             xmlns:models="clr-namespace:Shutool.Models"
             x:Class="Shutool.Views.DriverHistoryPage"
             x:DataType="viewmodels:DriverHistoryViewModel"
             BackgroundColor="#F5EFE1"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto, *" Padding="0">

        <Grid Grid.Row="0" Padding="20">
            <Grid ColumnDefinitions="*, *">
                <Image Source="gear_icon.png" HorizontalOptions="Start" VerticalOptions="Start" HeightRequest="30">
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToProfileCommand}" />
                    </Image.GestureRecognizers>
                </Image>
                <Image Source="lightning_icon.png" Grid.Column="1" HorizontalOptions="End" VerticalOptions="Start" HeightRequest="30"/>
            </Grid>

            <VerticalStackLayout HorizontalOptions="Center" Spacing="5" Margin="0,20,0,0">
                <Border StrokeShape="RoundRectangle 40" HeightRequest="80" WidthRequest="80" StrokeThickness="2" Stroke="Black">
                    <Image Source="driver_avatar.png" Aspect="AspectFill"/>
                </Border>
                <Border BackgroundColor="#F5C518" StrokeShape="RoundRectangle 15" Padding="20,5" StrokeThickness="0" Margin="0,10,0,0">
                    <Label Text="Victor Manalo" TextColor="Black" FontAttributes="Bold" HorizontalOptions="Center"/>
                </Border>
                <Label Text="Shuttle #01" TextColor="Black" HorizontalOptions="Center" FontSize="12"/>
            </VerticalStackLayout>
        </Grid>

        <Border Grid.Row="1" BackgroundColor="#2D3A2D" StrokeShape="RoundRectangle 40,40,0,0" StrokeThickness="0" Padding="20, 30, 20, 20" Margin="0,20,0,0">
            <Grid RowDefinitions="Auto, Auto, *, Auto">

                <Grid Grid.Row="0" ColumnDefinitions="*, *" ColumnSpacing="10" Margin="0,0,0,20">
                    <Button Text="Pending Request" Command="{Binding GoBackToPendingCommand}" BackgroundColor="#4A5D4A" TextColor="White" FontAttributes="Bold" CornerRadius="20" HeightRequest="40"/>
                    <Button Grid.Column="1" Text="Request History" BackgroundColor="#F5C518" TextColor="#1E3B20" FontAttributes="Bold" CornerRadius="20" HeightRequest="40"/>
                </Grid>

                <Label Grid.Row="1" Text="Request History" TextColor="#F5C518" FontAttributes="Bold" FontSize="18" HorizontalOptions="Center" Margin="0,0,0,15"/>

                <Border Grid.Row="2" BackgroundColor="#F5EFE1" StrokeShape="RoundRectangle 10" StrokeThickness="0" Padding="15">
                    <Grid RowDefinitions="Auto, *">
                        <Grid Grid.Row="0" ColumnDefinitions="1.5*, 2*, 1*" Margin="0,0,0,10">
                            <Label Text="Date" TextColor="Black" FontAttributes="Bold" FontSize="12"/>
                            <Label Grid.Column="1" Text="Name" TextColor="Black" FontAttributes="Bold" FontSize="12"/>
                            <Label Grid.Column="2" Text="Status" TextColor="Black" FontAttributes="Bold" FontSize="12"/>
                        </Grid>

                        <CollectionView Grid.Row="1" ItemsSource="{Binding HistoryRequests}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:DriverRequestDisplayModel">
                                    <Grid ColumnDefinitions="1.5*, 2*, 1*" Padding="0,15">
                                        <Label Text="{Binding DateFormatted}" TextColor="Black" FontSize="12" VerticalOptions="Center"/>
                                        <Label Grid.Column="1" Text="{Binding RiderName}" TextColor="Black" FontSize="12" VerticalOptions="Center"/>
                                        <Label Grid.Column="2" Text="{Binding Status}" TextColor="#2D3A2D" FontAttributes="Bold" FontSize="12" VerticalOptions="Center"/>
                                        <BoxView Grid.ColumnSpan="3" HeightRequest="1" Color="#E0D8C8" VerticalOptions="End"/>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Grid>
                </Border>

                <Grid Grid.Row="3" ColumnDefinitions="*, *" ColumnSpacing="10" Margin="0,20,0,0">
                    <Button Text="Clear History" Command="{Binding ClearHistoryCommand}" BackgroundColor="#FF6B6B" TextColor="White" FontAttributes="Bold" CornerRadius="20" HeightRequest="40"/>
                    <Button Grid.Column="1" Text="Refresh" Command="{Binding LoadHistoryCommand}" BackgroundColor="#5299D3" TextColor="White" FontAttributes="Bold" CornerRadius="20" HeightRequest="40"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</ContentPage>