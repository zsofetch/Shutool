<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Shutool.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Shutool.Views"
    Shell.FlyoutBehavior="Disabled">

    <ShellContent
        Route="LoginPage"
        ContentTemplate="{DataTemplate views:LoginPage}" />

    <ShellContent
        Route="RiderHome"
        ContentTemplate="{DataTemplate views:RiderMainPage}" />

    <ShellContent
        Route="DriverPending"
        ContentTemplate="{DataTemplate views:DriverPendingPage}" />

    <ShellContent
        Route="AdminManage"
        ContentTemplate="{DataTemplate views:AdminManagePage}" />

</Shell>