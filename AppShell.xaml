<?xml version="1.0" encoding="UTF-8" ?>
<Shell x:Class="Shutool.AppShell"
       xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:Shutool.Views">

    <ShellItem Route="Auth">
        <ShellContent Route="SplashPage" ContentTemplate="{DataTemplate views:SplashPage}" />
        <ShellContent Route="LoginPage" ContentTemplate="{DataTemplate views:LoginPage}" />
    </ShellItem>

    <ShellItem Route="AdminManage">
        <ShellContent ContentTemplate="{DataTemplate views:AdminManagePage}" />
    </ShellItem>

</Shell>